{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI evaluation card",
  "type": "object",
  "required": [
    "evaluation_id",
    "organization_id",
    "project_id",
    "scope",
    "finding",
    "severity",
    "confidence",
    "evidence",
    "recommended_next_step",
    "approval_tier"
  ],
  "properties": {
    "evaluation_id": {
      "type": "string"
    },
    "organization_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "finding": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "competing_explanations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_data": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "business_impact": {
      "type": "string"
    },
    "recommended_next_step": {
      "type": "string"
    },
    "approval_tier": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "status": {
      "enum": [
        "open",
        "accepted",
        "dismissed",
        "converted_to_task",
        "resolved"
      ]
    }
  },
  "additionalProperties": false
}
