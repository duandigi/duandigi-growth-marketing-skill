{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project asset mapping",
  "type": "object",
  "required": [
    "mapping_id",
    "organization_id",
    "project_id",
    "connection_id",
    "provider",
    "asset_type",
    "asset_id",
    "relationship",
    "status"
  ],
  "properties": {
    "mapping_id": {
      "type": "string"
    },
    "organization_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "connection_id": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "asset_type": {
      "type": "string"
    },
    "asset_id": {
      "type": "string"
    },
    "asset_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "relationship": {
      "enum": [
        "primary",
        "secondary",
        "shared",
        "historical",
        "excluded"
      ]
    },
    "status": {
      "enum": [
        "proposed",
        "confirmed",
        "rejected",
        "archived"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "filters": {
      "type": "object"
    },
    "approved_by": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
