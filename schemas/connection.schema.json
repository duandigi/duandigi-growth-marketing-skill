{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Connection metadata",
  "type": "object",
  "required": [
    "connection_id",
    "organization_id",
    "provider",
    "access_mode",
    "status"
  ],
  "properties": {
    "connection_id": {
      "type": "string",
      "minLength": 1
    },
    "organization_id": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "provider_account_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "access_mode": {
      "enum": [
        "observe",
        "prepare",
        "execute_with_approval"
      ]
    },
    "status": {
      "enum": [
        "pending",
        "healthy",
        "degraded",
        "action_required",
        "revoked",
        "unavailable"
      ]
    },
    "granted_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "secret_reference": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_successful_sync_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
