{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://duandigi.com/schemas/growth-experiment.schema.json",
  "title": "Growth Experiment",
  "type": "object",
  "required": [
    "experiment_id",
    "project_id",
    "hypothesis",
    "primary_metric",
    "decision_rule",
    "status"
  ],
  "properties": {
    "experiment_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "hypothesis": {
      "type": "string"
    },
    "audience": {
      "type": "string"
    },
    "intervention": {
      "type": "string"
    },
    "primary_metric": {
      "type": "string"
    },
    "guardrail_metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_rule": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "review",
        "approved",
        "running",
        "paused",
        "completed",
        "stopped"
      ]
    },
    "scores": {
      "type": "object",
      "properties": {
        "impact": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "confidence": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "strategic_fit": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "reusability": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "revenue_relevance": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "effort": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "risk": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        }
      }
    }
  },
  "additionalProperties": true
}
